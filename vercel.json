{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "story-generator/dist/story-generator/browser",
  "framework": null,
  "installCommand": "npm run install:all",
  "rewrites": [
    {
      "source": "/api/story-lab/jobs/:jobId/events",
      "destination": "/api/story-lab/jobs?jobId=:jobId&events=1"
    },
    {
      "source": "/api/story-lab/jobs/:jobId",
      "destination": "/api/story-lab/jobs?jobId=:jobId"
    },
    {
      "source": "/api/story-lab/account/profile",
      "destination": "/api/story-lab/account?resource=profile"
    },
    {
      "source": "/api/story-lab/account/projects/:projectId",
      "destination": "/api/story-lab/account?resource=project&projectId=:projectId"
    },
    {
      "source": "/api/story-lab/account/projects",
      "destination": "/api/story-lab/account?resource=projects"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60
    }
  }
}
