    "test:all": "npm run test:story && npm run test:tropes && npm run test:cliffhangers && npm run test:story-lab-state && npm run test:story-lab-real-engine && npm run test:story-lab-auth && npm run test:story-lab-configured-auth && npm run test:story-lab-clerk-auth && npm run test:story-lab-storage-port && npm run test:story-lab-cloud-schema && npm run test:story-lab-cloud-storage-config && npm run test:story-lab-neon-executor && npm run test:story-lab-cloud-schema-migration && npm run test:story-lab-cloud-db-readiness && npm run test:story-lab-profile-contracts && npm run test:story-lab-profile-store && npm run test:story-lab-account-routes && npm run test:story-quality",
