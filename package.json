{
  "private": true,
  "scripts": {
    "install:all": "npm install --no-audit --no-fund && cd story-generator && npm install --no-audit --no-fund",
    "build": "cd story-generator && npm run build && cd .. && npm run build:vercel-index",
    "build:vercel-index": "scripts/recovery/ensure-vercel-index.sh",
    "build:verify": "npm run build:vercel-index && test -f story-generator/dist/story-generator/browser/index.html",
    "build:full": "npm run build && npm run build:verify",
    "test": "npm run test:all",
    "test:story": "tsx tests/story-service-improved.test.ts",
    "test:tropes": "tsx tests/trope-subversion.test.ts",
    "test:cliffhangers": "tsx tests/cliffhanger-service.test.ts",
    "test:story-lab-state": "tsx tests/story-lab-state.test.ts",
    "test:story-lab-real-engine": "tsx tests/story-lab-real-engine.test.ts",
    "test:story-quality": "tsx tests/story-quality-evals.test.ts",
    "test:all": "npm run test:story && npm run test:tropes && npm run test:cliffhangers && npm run test:story-lab-state && npm run test:story-lab-real-engine && npm run test:story-quality",
    "smoke:grok": "tsx tests/grok-multi-agent-smoke.test.ts",
    "smoke:grok-multi-agent": "tsx tests/grok-multi-agent-smoke.test.ts",
    "smoke:story-lab-ui": "node scripts/recovery/story-lab-browser-smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "playwright": "^1.60.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dotenv": "^17.2.2"
  }
}
